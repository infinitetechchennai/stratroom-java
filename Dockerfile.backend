FROM maven:3.9-eclipse-temurin-21-alpine AS builder
WORKDIR /build

COPY backend/pom.xml pom.xml
COPY backend/stratroom-backend stratroom-backend
COPY backend/licenseservice licenseservice

RUN mvn package -pl stratroom-backend -am -DskipTests --no-transfer-progress

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=builder /build/stratroom-backend/target/stratroom-backend-0.0.1.jar app.jar
VOLUME ["/uploads"]
EXPOSE 8085
ENTRYPOINT ["java", "-jar", "app.jar"]
