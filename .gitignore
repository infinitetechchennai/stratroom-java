# =============================================
# StratRoom — .gitignore
# =============================================

# ===== Node / Frontend =====
node_modules/
dist/
dist-ssr/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Java / Maven =====
target/
*.class
*.jar
*.war
*.ear
*.nar

# ===== IDE & Editor =====
.project
.classpath
.settings/
.idea/
*.iml
.vscode/
.metadata/
*.suo
*.sw?

# ===== Spring Boot local overrides (never commit real secrets) =====
application-local.properties
application-local.yml

# ===== Environment / Secrets =====
.env
.env.*
!.env.example

# ===== OS generated =====
.DS_Store
Thumbs.db

# ===== Logs & runtime output =====
logs/
*.log
*.gz

# ===== Binary / Archive files =====
*.zip
*.xlsx
*.xls
*.docx
*.doc
*.pdf

# ===== One-off dev scratch scripts =====
# These belong on the developer's machine only, never in the repo
*.py
*.bat
*.cjs
fix_modals.js
test_sc.js

# ===== Local reference / notes =====
db table config.txt
orgpsql
orgstructurev2.sql
Risk Full Logic.html
backend/Risk Full Logic (1).html

# ===== Legacy scratch directories =====
stratroom-java-master/
backend/my-new-update-06/
frontend/Untitled/
testing-data/
extracted_cal.css
org-structure_calendar_dw_*

# ===== Local import files =====
import files/
import-files/
import-templates/
