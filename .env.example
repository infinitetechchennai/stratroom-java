# =============================================
# StratRoom — Environment Variables Template
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit your real .env to git.
#
# Usage:
#   cp .env.example .env
#   nano .env          # fill in your values
#   docker compose up -d --build

# ===== Database =====
DB_USERNAME=postgres
DB_PASSWORD=change_me_strong_password

# ===== JWT (must be at least 32 characters) =====
JWT_SECRET=replace_with_a_random_64_char_hex_string

# ===== Jasypt Encryption =====
JASYPT_PASSWORD=replace_with_a_strong_encryption_password

# ===== Admin Seed User (used only on first run) =====
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_password

# ===== Mail / SMTP (leave blank to disable emails) =====
MAIL_SMTP_PASSWORD=

# ===== LDAP (leave blank if not using LDAP) =====
LDAP_BIND_PASSWORD=

# ===== Amazon S3 (leave blank to use local file storage) =====
AWS_ENDPOINT_URL=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
