<infinispan xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="urn:infinispan:config:9.4 https://infinispan.org/schemas/infinispan-config-9.4.xsd"
	xmlns="urn:infinispan:config:9.4">
	<jgroups>
		<stack-file name="tcp" path="jgroups.xml" />
	</jgroups>
	<cache-container>
		<transport stack="tcp" node-name="Node-A"></transport>
		<jmx domain="org.infinispan"></jmx>
		<!-- <distributed-cache name="dbCache" mode="SYNC" l1-lifespan="60000"
			owners="2"></distributed-cache>-->
	</cache-container>
</infinispan>